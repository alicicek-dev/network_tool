{
  "name": "network_tool",
  "private": true,
  "version": "1.0.2",
  "author": "Ali Cicek",
  "description": "Network Engineer Toolkit",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.networktool.app",
    "publish": {
      "provider": "github",
      "owner": "alicicek-dev",
      "repo": "network_tool"
    },
    "productName": "NetTool",
    "win": {
      "requestedExecutionLevel": "highestAvailable",
      "target": [
        "nsis",
        "portable",
        "appx"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NetTool",
      "runAfterFinish": true
    },
    "appx": {
      "identityName": "AliEK.NetTool-NetworkEngineerToolkit",
      "publisher": "CN=677A4992-D291-47EE-91C0-263033D625D1",
      "publisherDisplayName": "Ali ÇİÇEK",
      "applicationId": "NetTool",
      "displayName": "NetTool - Network Engineer Toolkit"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "server.js",
      "servers-manager.js",
      "package.json"
    ]
  },
  "dependencies": {
    "@types/chroma-js": "^3.1.2",
    "@xterm/addon-fit": "^0.11.0",
    "chroma-js": "^3.2.0",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "ftp-srv": "^4.6.3",
    "ping": "^1.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "selfsigned": "^5.5.0",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ssh2": "^1.17.0",
    "tftp2": "^0.0.1",
    "wake_on_lan": "^1.0.0",
    "whois-json": "^2.0.4",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  }
}
